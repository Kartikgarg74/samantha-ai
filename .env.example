# Samantha AI Agent — Environment Variables
# Copy this to .env and fill in your values

# ========== LLM Provider (at least one required) ==========
GOOGLE_API_KEY=           # Get from https://aistudio.google.com/
OLLAMA_MODEL=llama3.2     # Used if Ollama is running locally (http://localhost:11434)
OLLAMA_URL=http://localhost:11434  # Ollama server address (default)

# ========== Optional Integrations ==========
# Spotify (for music control)
SPOTIFY_CLIENT_ID=        # Get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_SECRET=    # Spotify app secret

# Weather (for weather queries)
WEATHER_API_KEY=          # Get from https://openweathermap.org/api

# News (for news queries)
NEWS_API_KEY=             # Get from https://newsapi.org/register

# ========== Development ==========
DEBUG_MODE=false
LOG_LEVEL=INFO
